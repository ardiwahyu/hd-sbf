<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.HDSBF" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimary</item>
        <item name="colorControlActivated">@color/colorPrimary</item>
        <item name="colorSwitchThumbNormal">@color/gray300</item>
        <item name="android:colorForeground">@color/gray600</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:textColor">@color/black</item>

        <!-- Warna hint untuk EditText (abu-abu muda) -->
        <item name="android:textColorHint">@color/gray</item>
        <!-- Untuk komponen Material3 (seperti label/hint TextInputLayout) -->
        <item name="colorOnSurfaceVariant">@color/gray</item>
    </style>

    <style name="Theme.HDSBF" parent="Base.Theme.HDSBF" />

    <style name="ToolBarStyle" parent="Theme.HDSBF">
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
        <item name="fontFamily">@font/nunito_semi_bold</item>
        <item name="android:fontFamily">@font/nunito_semi_bold</item>
        <item name="actionMenuTextColor">@color/white</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:actionMenuTextColor">@color/white</item>
    </style>

    <style name="MaterialDialogSheet" parent="Theme.HDSBF">
        <item name="android:backgroundDimAmount">0.5</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowBackground">@color/black_overlay</item>
        <item name="windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowAnimationStyle">@style/MaterialDialogSheetAnimation</item>
    </style>

    <style name="CustomDatePickerLight" parent="ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnSurface">@color/black</item>
        <!-- Mengubah warna teks bulan/tahun agar lebih terang (hitam) -->
        <item name="colorOnSurfaceVariant">@color/black</item>
    </style>

    <style name="MaterialDialogSheetAnimation">
        <item name="android:windowEnterAnimation">@anim/alert_present</item>
        <item name="android:windowExitAnimation">@anim/alert_dismiss</item>
    </style>

    <style name="Theme.HDSBF.AppWidgetContainerParent" parent="@android:style/Theme.DeviceDefault">
        <!-- Radius of the outer bound of widgets to make the rounded corners -->
        <item name="appWidgetRadius">16dp</item>
        <!--
        Radius of the inner view's bound of widgets to make the rounded corners.
        It needs to be 8dp or less than the value of appWidgetRadius
        -->
        <item name="appWidgetInnerRadius">8dp</item>
    </style>

    <style name="Theme.HDSBF.AppWidgetContainer" parent="Theme.HDSBF.AppWidgetContainerParent">
        <!-- Apply padding to avoid the content of the widget colliding with the rounded corners -->
        <item name="appWidgetPadding">16dp</item>
    </style>
</resources>
